# Casa Coffee Colab — variáveis de ambiente do CLIENT (expostas no bundle).
# Copie este arquivo pra .env e preencha com os valores do teu projeto Supabase.
# NUNCA coloque aqui (nem no .env do client) chaves secretas: service_role,
# STRIPE_SECRET_KEY, STRIPE_WEBHOOK_SECRET, POS_WEBHOOK_SECRET — essas vivem
# SÓ nas env vars das Edge Functions. Ver CLAUDE.md › Segurança.
#
# Só variáveis com prefixo VITE_ chegam ao client (regra do Vite).

# URL do projeto Supabase (ex.: https://xxxxxxxxxxxx.supabase.co)
VITE_SUPABASE_URL=

# Chave ANON (pública, segura pro client — a RLS é quem protege os dados).
VITE_SUPABASE_ANON_KEY=

# Base URL do site pros links de e-mail (confirmação/reset de senha).
# Opcional: se ficar em branco/ausente, usa a origin atual (window.location.origin).
# Em produção, aponte pro domínio final da Vercel (ex.: https://casacoffeecolab.com.br).
# NÃO deixe "VITE_SITE_URL=" vazio se quiser o fallback — comente ou remova a linha.
# VITE_SITE_URL=

